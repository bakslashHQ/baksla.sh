{% extends 'pages/base.html.twig' %}

{% block title %}{{ 'team.seo.title'|trans|raw }}{% endblock %}

{% block seo %}
    <meta name="description" content="{{ 'team.seo.description'|trans|raw }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ 'team.seo.title'|trans|raw }}">
    <meta property="og:description" content="{{ 'team.seo.description'|trans|raw }}">
    <meta property="og:image" content="{{ absolute_url(asset('images/og.png')) }}">
    <meta property="og:image:alt" content="{{ 'team.seo.title'|trans|raw }}">
{% endblock %}

{% block content %}
    {% set memberIds = members|keys %}
    {% set total = memberIds|length %}
    {% for member in members %}
        <twig:Team:MemberModal
            :member="member"
            :prev="memberIds[(loop.index0 - 1 + total) % total]"
            :next="memberIds[(loop.index0 + 1) % total]"
        />
    {% endfor %}

    <section class="relative overflow-hidden">
        <div aria-hidden="true" class="absolute inset-0 dot-grid pointer-events-none"></div>
        <div class="container max-w-screen-xl mx-auto px-4 sm:px-8 xl:px-4 pt-12 sm:pt-16 lg:pt-24 relative">
            <header class="pb-16 sm:pb-20 lg:pb-28">
                <div aria-hidden="true" class="font-mono text-xs uppercase tracking-widest text-accent mb-3">{{ 'team.caption'|trans }}</div>
                <h1 class="m-0 font-sans font-bold leading-[0.92] tracking-tighter text-5xl sm:text-6xl lg:text-8xl text-ink text-balance">
                    {{- 'team.title'|trans|replace({
                        '<0>': '<span class="text-accent">',
                        '</0>': '</span>',
                    })|raw -}}
                    <twig:ux:icon name="noto:shushing-face" aria-hidden="true" class="inline-block align-middle ml-2 size-8 sm:size-10 lg:size-16" />
                </h1>
            </header>
        </div>
    </section>

    <div class="container max-w-screen-xl mx-auto px-4 sm:px-8 xl:px-4">
        <section aria-label="{{ 'team.pr.tag'|trans }}">
            <div class="lg:hidden mb-6">
                <twig:Team:ProTip />
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_18rem] gap-x-8 gap-y-10">
                <twig:Team:CodeView :members="members" />
                <twig:Team:Reviewers :members="members" />
            </div>
        </section>
    </div>
{% endblock %}
