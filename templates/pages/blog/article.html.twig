{% extends 'pages/base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block seo %}
    <meta name="description" content="{{ article.description }}">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ article.title }}">
    <meta property="og:description" content="{{ article.description }}">
    <meta property="og:image" content="{{ absolute_url('/open-graph/article/' ~ article.id ~ '.jpg') }}">
{% endblock %}

{% block main_class %}bg-gray-50{% endblock %}

{% block content %}
    <section aria-label="Article" class="py-12 sm:py-16">
        <div class="mx-auto max-w-5xl px-6 lg:px-8">

            {# Breadcrumb — repo file path style #}
            <div class="flex items-center gap-1.5 text-sm mb-6 min-w-0 overflow-hidden">
                <twig:UX:Icon name="octicon:repo" aria-hidden="true" class="size-4 text-gray-400 shrink-0" />
                <a href="{{ path('app_home') }}" class="text-indigo-600 hover:underline underline-offset-2 shrink-0">baksla.sh</a>
                <span class="text-gray-300 shrink-0">/</span>
                <a href="{{ path('app_home') }}#blog" class="text-indigo-600 hover:underline underline-offset-2 shrink-0 max-sm:hidden">{{ 'blog.title'|trans }}</a>
                <span class="text-gray-300 shrink-0 max-sm:hidden">/</span>
                <span class="text-slate-700 font-semibold truncate">{{ article.id }}.md</span>
            </div>

            {# File card #}
            <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm overflow-hidden">

                {# Header — author + date #}
                <div class="px-6 py-3 bg-gray-50 border-b border-gray-200 flex items-center justify-between text-sm">
                    <div class="flex items-center gap-2.5">
                        <img class="size-5 rounded-full ring-1 ring-gray-200" src="{{ asset('images/team/members/' ~ article.author.id.value ~ '.jpg') }}" alt="{{ article.author.fullName }}" loading="lazy" width="20" height="20">
                        <span class="font-semibold text-slate-800">{{ article.author.fullName }}</span>
                        <span class="text-gray-400 max-sm:hidden">{{ 'home.team.authored_this_article'|trans }}</span>
                    </div>
                    <span class="text-xs text-gray-400">{{ article.publishedAt|date('M j, Y') }}</span>
                </div>

                {# Rendered markdown content #}
                <div class="px-6 sm:px-10 py-8 sm:py-10">
                    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight pb-4 mb-6 border-b border-gray-200">{{ article.title }}</h1>
                    <p class="text-base text-gray-500 mb-8">{{ article.description }}</p>
                    <div class="markdown-body text-gray-700 text-base font-article" data-test-article>
                        {{ article.html|raw }}
                    </div>
                </div>

            </div>

            {# More from the blog #}
            {% if more|length > 0 %}
                <div class="mt-12 sm:mt-16">
                    <div class="flex items-center gap-2 mb-4">
                        <twig:UX:Icon name="octicon:file" aria-hidden="true" class="size-4 text-gray-400" />
                        <h2 class="text-sm font-semibold text-slate-800">{{ 'blog.article.more_from_the_blog'|trans|replace({'<0>': '', '</0>': ''})|raw }}</h2>
                    </div>

                    <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm overflow-hidden">
                        {% for preview in more %}
                            {% if preview %}
                                <a href="{{ path('app_blog_article', {id: preview.id}) }}" class="group flex items-start gap-4 px-6 py-5 {{ not loop.last ? 'border-b border-gray-200' }} hover:bg-gray-50 transition">
                                    <twig:UX:Icon name="octicon:file" aria-hidden="true" class="size-5 text-gray-300 shrink-0 mt-0.5" />
                                    <div class="min-w-0 flex-1">
                                        <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1">
                                            <h3 class="text-base font-semibold text-slate-900 group-hover:text-indigo-600 transition">{{ preview.title }}</h3>
                                            <span class="text-xs text-gray-400 shrink-0 mt-0.5">{{ preview.publishedAt|date('M j, Y') }}</span>
                                        </div>
                                        <p class="mt-2 text-sm text-gray-500 line-clamp-2">{{ preview.description }}</p>
                                        <div class="mt-3 flex items-center gap-2 text-xs text-gray-400">
                                            <img class="size-4 rounded-full" src="{{ asset('images/team/members/' ~ preview.author.id.value ~ '.jpg') }}" alt="{{ preview.author.fullName }}" loading="lazy" width="16" height="16">
                                            <span>{{ preview.author.fullName }}</span>
                                        </div>
                                    </div>
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

        </div>
    </section>
{% endblock %}
