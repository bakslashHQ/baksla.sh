{% extends 'pages/base.html.twig' %}

{% block title %}{{ article.title }} — baksla.sh{% endblock %}

{% block seo %}
    <meta name="description" content="{{ article.description }}">
    <meta name="author" content="{{ article.author.fullname }}">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ article.title }}">
    <meta property="og:description" content="{{ article.description }}">
    <meta property="og:image" content="{{ absolute_url('/open-graph/article/' ~ article.id ~ '.jpg') }}">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ article.title }}">
    <meta property="article:published_time" content="{{ article.publishedAt|date('c') }}">
    <meta property="article:author" content="{{ article.author.fullname }}">
    <link rel="alternate" type="text/markdown" href="{{ url('app_blog_article', {id: article.id, _format: 'md'}) }}">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {{ article.title|json_encode|raw }},
        "description": {{ article.description|json_encode|raw }},
        "image": {{ absolute_url('/open-graph/article/' ~ article.id ~ '.jpg')|json_encode|raw }},
        "datePublished": "{{ article.publishedAt|date('c') }}",
        "author": {
            "@type": "Person",
            "name": {{ article.author.fullname|json_encode|raw }},
            "url": {{ ('https://github.com/' ~ article.author.github)|json_encode|raw }}
        },
        "publisher": {
            "@type": "Organization",
            "name": "baksla.sh",
            "logo": {
                "@type": "ImageObject",
                "url": {{ absolute_url(asset('images/bakslash-small.png'))|json_encode|raw }}
            }
        },
        "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": {{ (app.request.schemeAndHttpHost ~ app.request.pathInfo)|json_encode|raw }}
        }
    }
    </script>
{% endblock %}

{% block content %}
    <twig:Blog:ArticleNav :article="article" />

    <article>
        <section class="relative overflow-hidden">
            <div aria-hidden="true" class="absolute inset-0 dot-grid pointer-events-none"></div>
            <div class="container max-w-3xl mx-auto px-4 sm:px-8 pt-12 relative">
                <twig:Blog:ArticleHeader :article="article" />
            </div>
        </section>

        <div class="container max-w-3xl mx-auto px-4 sm:px-8">
            <div data-article-body data-test-article tabindex="-1" class="prose-body pt-10 mx-auto max-w-[68ch] font-article text-base sm:text-[1.125rem] leading-[1.7] text-ink text-pretty hyphens-auto focus:outline-none">
                {{- article.html|raw -}}
            </div>
        </div>
    </article>
{% endblock %}
