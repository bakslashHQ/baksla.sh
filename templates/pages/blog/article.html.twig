{% extends 'pages/base.html.twig' %}

{% block title %}{{ article.title }} — baksla.sh{% endblock %}

{% block seo %}
    <meta name="description" content="{{ article.description }}">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ article.title }}">
    <meta property="og:description" content="{{ article.description }}">
    <meta property="og:image" content="{{ absolute_url('/open-graph/article/' ~ article.id ~ '.jpg') }}">
{% endblock %}

{% block content %}
    <twig:Blog:ArticleNav :article="article" />

    <article class="container max-w-3xl mx-auto px-4 sm:px-8 pt-12">
        <twig:Blog:ArticleHeader :article="article" />

        <div data-article-body data-test-article tabindex="-1" class="prose-body pt-10 mx-auto max-w-[68ch] font-article text-base sm:text-[1.125rem] leading-[1.7] text-ink text-pretty hyphens-auto focus:outline-none">
            {{- article.html|raw -}}
        </div>
    </article>
{% endblock %}
