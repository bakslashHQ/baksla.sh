{% extends 'pages/base.html.twig' %}

{% block title %}{{ 'home.tabs.open_source'|trans }} | {{ 'home.seo.title'|trans|raw }}{% endblock %}

{% block seo %}
    <meta name="description" content="{{ 'open_source.seo.description'|trans }}">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ 'open_source.seo.title'|trans }}">
    <meta property="og:description" content="{{ 'open_source.seo.description'|trans }}">
    <meta property="og:image" content="{{ absolute_url(asset('images/og.png')) }}">
{% endblock %}

{% block main_class %}bg-gray-50{% endblock %}

{% block content %}
    <twig:OpenSourceOverview />
{% endblock %}
