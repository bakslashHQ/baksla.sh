{% extends 'pages/base.html.twig' %}

{% block title %}{{ 'home.seo.title'|trans|raw }}{% endblock %}

{% block seo %}
    <meta name="description" content="{{ 'home.seo.description'|trans|raw }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ 'home.seo.title'|trans|raw }}">
    <meta property="og:description" content="{{ 'home.seo.description'|trans|raw }}">
    <meta property="og:image" content="{{ absolute_url(asset('images/og.png')) }}">
    <meta property="og:image:alt" content="{{ 'home.seo.title'|trans|raw }}">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "baksla.sh",
        "url": {{ url('app_home')|json_encode|raw }},
        "logo": {{ absolute_url(asset('images/bakslash-small.png'))|json_encode|raw }},
        "description": {{ 'home.seo.description'|trans|json_encode|raw }},
        "sameAs": [
            "https://github.com/bakslashHQ",
            "https://x.com/BakslashHQ",
            "https://bsky.app/profile/baksla.sh",
            "https://www.linkedin.com/company/bakslashhq"
        ]
    }
    </script>
{% endblock %}

{% block content %}
    <twig:Home:Hero />
    <twig:Home:Kpi />
    <twig:Home:Separator />
    <twig:Home:Values />
    <twig:Home:Separator />
    <twig:Home:Products />
    <twig:Home:Separator />
    <twig:Home:OpenSourceOverview />
    <twig:Home:Separator />
    <twig:Home:BlogOverview />
    <twig:Home:Separator />
    <twig:Home:Clients />
{% endblock %}
