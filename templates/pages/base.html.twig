<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="scroll-pt-[10rem]">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{% endblock %}</title>

        <!-- Styles -->
        {% block stylesheets %}
            <style>
                /* Generated through fontpie, e.g.: "pnpx fontpie ./Poppins-SemiBold.woff2" */
                @font-face { font-family: 'Poppins Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 92.83%; descent-override: 30.94%; line-gap-override: 8.84%; size-adjust: 113.11%; }
                @font-face { font-family: 'Poppins Medium Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 91.82%; descent-override: 30.61%; line-gap-override: 8.74%; size-adjust: 114.36%; }
                @font-face { font-family: 'Poppins SemiBold Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 90.85%; descent-override: 30.28%; line-gap-override: 8.65%; size-adjust: 115.57%; }
                @font-face { font-family: 'Poppins Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 89.77%; descent-override: 29.92%; line-gap-override: 8.55%; size-adjust: 116.97%; }
                @font-face { font-family: 'Poppins ExtraBold Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 88.85%; descent-override: 29.62%; line-gap-override: 8.46%; size-adjust: 118.17%; }
                @font-face { font-family: 'Inter Light Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 91.42%; descent-override: 22.76%; line-gap-override: 0.00%; size-adjust: 105.97%; }
                @font-face { font-family: 'Inter Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 86.99%; descent-override: 21.66%; line-gap-override: 0.00%; size-adjust: 111.36%; }
                @font-face { font-family: 'Inter Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 89.79%; descent-override: 22.36%; line-gap-override: 0.00%; size-adjust: 107.89%; }
                @font-face { font-family: 'JetBrains Mono Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 77.57%; descent-override: 22.82%; line-gap-override: 0.00%; size-adjust: 131.49%; }
                @font-face { font-family: 'Space Grotesk Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 88.78%; descent-override: 26.34%; line-gap-override: 0.00%; size-adjust: 110.84%; }
            </style>
        {% endblock %}

        <!-- Scripts -->
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        <!-- Metadata & cie -->
        {% block seo %}
        {% endblock %}

        <!-- Favicon links -->
        <link rel="icon" type="image/png" href="{{ asset('images/favicon-96x96.png') }}" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="{{ asset('images/favicon.svg') }}">
        <link rel="shortcut icon" href="{{ asset('images/favicon.ico') }}">
    </head>
    <body class="bg-paper min-h-screen flex flex-col font-poppins">
        <div data-controller="analytics" data-analytics-measurement-id-value="{{ ga_measurement_id }}" data-analytics-app-name-value="{{ ga_app_name }}"></div>

        {% block body %}
            <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-white focus:text-slate-800 focus:underline">
                {{- 'header.skip_to_content'|trans -}}
            </a>

            <twig:website:Navbar />

            <main id="main-content" class="grow">
                {% block content %}{% endblock %}
            </main>

            <footer class="py-10">
                <div class="container max-w-screen-xl mx-auto px-4 md:px-8 flex items-center md:flex-row flex-col md:justify-between">
                    <span class="text-sm text-slate-700 flex items-center md:justify-start justify-center">
                        {{- 'footer.copyright'|trans({year: 'now'|date('Y')}) -}}
                    </span>
                    <ul class="flex flex-wrap justify-center items-center mt-3 text-slate-700 text-sm sm:mt-0">
                        <li>
                            <a href="{{ path('app_blog') }}" class="hover:underline me-4 md:me-6 py-4">
                                {{- 'footer.link.blog'|trans -}}
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_team') }}" class="hover:underline me-4 md:me-6 py-4">
                                {{- 'footer.link.team'|trans -}}
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_legal_notices') }}" class="hover:underline me-4 md:me-6 py-4">
                                {{- 'footer.link.legal_notices'|trans -}}
                            </a>
                        </li>
                    </ul>
                    <ul class="flex flex-wrap justify-center items-center mt-3 text-sm font-medium sm:mt-0">
                        <li class="h-full">
                            <a href="https://github.com/bakslashHQ" aria-label="{{ 'footer.social.github'|trans }}" target="_blank" class="hover:underline me-4 md:me-6 h-full flex items-center">
                                <twig:UX:Icon name="logos:github" aria-hidden="true" class="h-5 mt-2 md:h-6 md:mt-0 opacity-70 hover:opacity-100 grayscale hover:grayscale-0 transition" />
                            </a>
                        </li>
                        <li>
                            <a href="https://x.com/BakslashHQ" aria-label="{{ 'footer.social.x'|trans }}" target="_blank" class="hover:underline me-4 md:me-6 h-full flex items-center">
                                <twig:UX:Icon name="logos:x" aria-hidden="true" class="h-5 mt-2 md:h-6 md:mt-0 opacity-70 hover:opacity-100 grayscale hover:grayscale-0 transition" />
                            </a>
                        </li>
                        <li>
                            <a href="https://bsky.app/profile/baksla.sh" aria-label="{{ 'footer.social.bluesky'|trans }}" target="_blank" class="hover:underline me-4 md:me-6 h-full flex items-center">
                                <twig:UX:Icon name="logos:bluesky" aria-hidden="true" class="h-5 mt-2 md:h-6 md:mt-0 opacity-70 hover:opacity-100 grayscale hover:grayscale-0 transition" />
                            </a>
                        </li>
                        <li>
                            <a href="https://www.linkedin.com/company/bakslashhq" aria-label="{{ 'footer.social.linkedin'|trans }}" target="_blank" class="hover:underline me-4 md:me-6 h-full flex items-center">
                                <twig:UX:Icon name="logos:linkedin" aria-hidden="true" class="h-5 mt-2 md:h-6 md:mt-0 opacity-70 hover:opacity-100 grayscale hover:grayscale-0 transition" />
                            </a>
                        </li>
                    </ul>
                </div>
            </footer>
        {% endblock %}
    </body>
</html>
