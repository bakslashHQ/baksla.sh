<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="bg-gray-900">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{% endblock %}</title>

        <!-- Styles -->
        {% block stylesheets %}
            <style>
                /* Generated through fontpie, e.g.: "pnpx fontpie ./Poppins-SemiBold.woff2" */
                @font-face { font-family: 'Kalam Light Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 114.42%; descent-override: 57.16%; line-gap-override: 0.00%; size-adjust: 92.90%; }
                @font-face { font-family: 'Kalam Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 110.75%; descent-override: 55.32%; line-gap-override: 0.00%; size-adjust: 95.98%; }
                @font-face { font-family: 'Kalam Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 104.53%; descent-override: 52.22%; line-gap-override: 0.00%; size-adjust: 101.69%; }
                @font-face { font-family: 'Poppins Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 92.83%; descent-override: 30.94%; line-gap-override: 8.84%; size-adjust: 113.11%; }
                @font-face { font-family: 'Poppins Medium Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 91.82%; descent-override: 30.61%; line-gap-override: 8.74%; size-adjust: 114.36%; }
                @font-face { font-family: 'Poppins SemiBold Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 90.85%; descent-override: 30.28%; line-gap-override: 8.65%; size-adjust: 115.57%; }
                @font-face { font-family: 'Poppins Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 89.77%; descent-override: 29.92%; line-gap-override: 8.55%; size-adjust: 116.97%; }
                @font-face { font-family: 'Poppins ExtraBold Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 88.85%; descent-override: 29.62%; line-gap-override: 8.46%; size-adjust: 118.17%; }
                @font-face { font-family: 'Inter Light Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 91.42%; descent-override: 22.76%; line-gap-override: 0.00%; size-adjust: 105.97%; }
                @font-face { font-family: 'Inter Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 86.99%; descent-override: 21.66%; line-gap-override: 0.00%; size-adjust: 111.36%; }
                @font-face { font-family: 'Inter Fallback'; font-style: normal; font-weight: 400; src: local('Arial'); ascent-override: 89.79%; descent-override: 22.36%; line-gap-override: 0.00%; size-adjust: 107.89%; }
            </style>
        {% endblock %}

        <!-- Scripts -->
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        <!-- Metadata & cie -->
        {% block seo %}
        {% endblock %}

        <!-- Favicon links -->
        <link rel="icon" type="image/png" href="{{ asset('images/favicon-96x96.png') }}" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="{{ asset('images/favicon.svg') }}">
        <link rel="shortcut icon" href="{{ asset('images/favicon.ico') }}">
    </head>
    <body class="bg-white min-h-screen flex flex-col">
        <div data-controller="analytics" data-analytics-measurement-id-value="{{ ga_measurement_id }}" data-analytics-app-name-value="{{ ga_app_name }}"></div>

        {% block body %}
            <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-white focus:text-slate-800 focus:underline">
                {{- 'header.skip_to_content'|trans -}}
            </a>

            <header class="bg-gray-900 sticky top-0 z-50">
                <div class="mx-auto max-w-5xl px-6 lg:px-8">
                    <nav class="flex items-center justify-between h-16">
                        <a href="{{ path('app_home') }}" title="baksla.sh" class="min-w-6">
                            <img src="{{ asset('images/bakslash-white.svg') }}" alt="baksla.sh" class="h-7 sm:h-8 w-auto" loading="eager" fetchpriority="high">
                        </a>
                        <div class="flex items-center gap-x-1 sm:gap-x-2">
                            <a href="{{ path('app_open_source') }}" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 rounded-md transition whitespace-nowrap max-sm:hidden">{{ 'home.tabs.open_source'|trans }}</a>
                            <a href="{{ path('app_team') }}" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 rounded-md transition whitespace-nowrap max-sm:hidden">{{ 'home.tabs.team'|trans }}</a>
                            <a href="{{ path('app_blog') }}" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 rounded-md transition whitespace-nowrap max-sm:hidden">{{ 'home.tabs.blog'|trans }}</a>
                            <a href="mailto:hello@baksla.sh" aria-label="hello@baksla.sh" class="inline-flex items-center gap-1.5 px-2.5 sm:px-3 py-1.5 text-sm font-medium text-white bg-green-600 hover:bg-green-500 rounded-md transition whitespace-nowrap">
                                <twig:UX:Icon name="octicon:mail" aria-hidden="true" class="size-4" />
                                <span class="hidden sm:inline">hello@baksla.sh</span>
                            </a>
                        </div>
                    </nav>
                </div>
            </header>

            <main id="main-content" class="grow {% block main_class %}{% endblock %}">
                {% block content %}{% endblock %}
            </main>

            <footer class="border-t border-gray-200 py-6">
                <div class="mx-auto max-w-5xl px-6 lg:px-8">
                    <div class="flex flex-col sm:grid sm:grid-cols-3 items-center gap-4">

                        {# Left: logo + copyright #}
                        <div class="flex items-center gap-4">
                            <a href="{{ path('app_home') }}" class="opacity-60 hover:opacity-100 transition">
                                <img src="{{ asset('images/bakslash-small.svg') }}" alt="baksla.sh" class="size-6" loading="lazy">
                            </a>
                            <span class="text-xs text-gray-500">{{ 'footer.copyright'|trans({year: 'now'|date('Y')}) }}</span>
                        </div>

                        {# Center: links #}
                        <nav class="flex flex-wrap items-center justify-center gap-x-5 text-xs text-gray-500">
                            <a href="{{ path('app_legal_notices') }}" class="hover:text-indigo-600 transition">{{ 'footer.link.legal_notices'|trans }}</a>
                            <a href="mailto:hello@baksla.sh" class="hover:text-indigo-600 transition">hello@baksla.sh</a>
                        </nav>

                        {# Right: social icons #}
                        <div class="flex items-center justify-end gap-3">
                            <a href="https://github.com/bakslashHQ" aria-label="{{ 'footer.social.github'|trans }}" target="_blank" class="opacity-60 hover:opacity-100 transition p-2">
                                <twig:UX:Icon name="logos:github" aria-hidden="true" class="size-4" />
                            </a>
                            <a href="https://x.com/BakslashHQ" aria-label="{{ 'footer.social.x'|trans }}" target="_blank" class="opacity-60 hover:opacity-100 transition p-2">
                                <twig:UX:Icon name="logos:x" aria-hidden="true" class="size-4" />
                            </a>
                            <a href="https://bsky.app/profile/baksla.sh" aria-label="{{ 'footer.social.bluesky'|trans }}" target="_blank" class="opacity-60 hover:opacity-100 transition p-2">
                                <twig:UX:Icon name="logos:bluesky" aria-hidden="true" class="size-4" />
                            </a>
                            <a href="https://www.linkedin.com/company/bakslashhq" aria-label="{{ 'footer.social.linkedin'|trans }}" target="_blank" class="opacity-60 hover:opacity-100 transition p-2">
                                <twig:UX:Icon name="logos:linkedin" aria-hidden="true" class="size-4" />
                            </a>
                        </div>

                    </div>
                </div>
            </footer>
        {% endblock %}
    </body>
</html>
