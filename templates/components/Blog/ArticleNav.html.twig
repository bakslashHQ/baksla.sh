<nav
    aria-label="{{ 'blog.article.nav_label'|trans }}"
    inert
    data-controller="article-nav"
    data-article-nav-reading-time-value="{{ article.readingTime }}"
    class="fixed top-16 sm:top-20 left-0 right-0 z-40 opacity-0 -translate-y-3 transition-all duration-300 ease-out bg-paper/90 backdrop-blur-md border-b border-ink/10"
>
    <div class="container max-w-screen-xl mx-auto px-4 sm:px-8 xl:px-4 py-3 flex items-center gap-3 sm:gap-4">
        <a
            href="{{ path('app_blog') }}"
            class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-ink-soft hover:text-accent no-underline shrink-0 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-full"
        >
            <span aria-hidden="true" class="inline-flex items-center justify-center size-7 rounded-full border border-ink/20 group-hover:border-accent group-hover:text-accent transition-colors">
                <twig:ux:icon name="mdi:arrow-left" class="size-3" />
            </span>
            <span class="sr-only sm:not-sr-only sm:inline">{{ 'blog.label'|trans }}</span>
        </a>
        <span aria-hidden="true" class="h-6 w-px bg-ink/15 hidden sm:block shrink-0"></span>
        <div class="flex-1 min-w-0 flex items-baseline gap-3">
            <p aria-hidden="true" class="m-0 font-sans font-semibold tracking-tight text-base sm:text-lg text-ink truncate">{{ article.title }}</p>
        </div>
        <span
            aria-hidden="true"
            data-article-nav-target="readout"
            class="hidden lg:inline font-mono text-xs uppercase tracking-widest text-muted shrink-0 tabular-nums"
        >0% · {{ article.readingTime }} min</span>
        <button
            type="button"
            data-action="article-nav#scrollToTop"
            aria-label="{{ 'blog.article.scroll_to_top'|trans }}"
            class="font-mono text-xs uppercase tracking-widest text-ink-soft hover:text-accent shrink-0 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-paper rounded-sm"
        >{{ 'blog.article.top'|trans }} <span aria-hidden="true">↑</span></button>
    </div>
</nav>
