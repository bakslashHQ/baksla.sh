<section
    aria-label="{{ 'home.hero.aria_label'|trans }}"
    class="relative overflow-hidden text-ink"
    data-controller="hero"
    data-hero-words-value="{{ [
        'home.hero.words.maintainers',
        'home.hero.words.lovers',
        'home.hero.words.advocates',
        'home.hero.words.developers',
    ]|map(word => word|trans)|json_encode }}"
>
    <div class="container max-w-screen-xl mx-auto px-4 sm:px-8 xl:px-4 pt-20 lg:pt-24 relative">
        <div class="grid grid-cols-1 gap-12">
            <div class="sr-only lg:not-sr-only lg:inline-flex font-mono text-xs tracking-widest uppercase text-muted items-center gap-2">
                <span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
                {{ 'home.hero.eyebrow'|trans }}
            </div>

            <h1 class="flex flex-col justify-center text-center lg:text-left font-sans font-normal leading-none tracking-tight lg:tracking-tighter m-0 text-6xl lg:text-8xl"
                aria-label="{{ 'home.hero.heading_aria_label'|trans }}">
                <span class="block text-4xl lg:text-7xl text-ink-soft">
                    {{ 'home.hero.heading_text'|trans }}
                </span>
                <span class="block">
                    <span class="font-bold text-accent tracking-tight">Symfony</span>
                    <br class="md:hidden" />
                    <span aria-hidden="true" data-hero-target="badge" class="inline-block min-w-28 lg:min-w-52 font-mono font-medium not-italic bg-ink text-paper px-4 lg:px-8 py-1.5 lg:py-2.5 rounded-full align-[0.28em] text-2xl lg:text-5xl"></span>
                </span>
            </h1>

            <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)] gap-6 lg:gap-12 items-end">
                <p class="text-center lg:text-left my-0 mx-auto lg:mx-0 font-sans text-base leading-normal text-ink-soft max-w-2xl">
                    {{ 'home.hero.tagline'|trans }}
                </p>
                <div class="flex flex-wrap gap-3 justify-center lg:justify-start justify-self-center lg:justify-self-start">
                    <a href="#services"
                       class="group inline-flex items-center gap-2.5 px-5 py-3.5 rounded-full border border-ink bg-ink text-paper font-mono text-sm font-medium no-underline transition duration-200 hover:bg-accent hover:border-accent hover:text-white hover:-translate-y-px focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-paper">
                        {{ 'home.hero.cta.primary'|trans }}
                        <twig:ux:icon
                            name="mdi:arrow-right"
                            aria-hidden="true"
                            class="size-4 transition-transform duration-200 group-hover:translate-x-1"
                        />
                    </a>
                    <a href="mailto:hello@baksla.sh"
                       class="inline-flex items-center gap-2.5 px-5 py-3.5 rounded-full border border-ink text-ink font-mono text-sm font-medium no-underline transition duration-200 hover:bg-ink hover:text-paper hover:-translate-y-px focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-paper">
                        {{ 'home.hero.cta.secondary'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
