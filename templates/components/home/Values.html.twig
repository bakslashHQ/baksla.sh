<section aria-label="baksla.sh's values" class="pt-12 sm:pt-16 pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">

        {# Release card #}
        <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm overflow-hidden">

            {# Header — like a GitHub release page #}
            <div class="px-6 sm:px-8 pt-8 sm:pt-10 pb-6 border-b border-gray-200">
                <div class="flex flex-wrap items-center gap-3 mb-3">
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-green-600 px-3 py-1 text-xs font-semibold text-white">
                        <twig:UX:Icon name="octicon:tag" aria-hidden="true" class="size-3.5" />
                        {{ 'home.code.latest'|trans }}
                    </span>
                    <span class="text-sm text-gray-500">{{ 'home.code.released_at'|trans }}</span>
                </div>
                <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight">baksla.sh</h2>
                <div class="flex items-center gap-2.5 mt-4">
                    <div class="flex -space-x-1.5">
                        <img class="size-6 rounded-full ring-2 ring-white" src="{{ asset('images/team/members/robin-chalas.jpg') }}" alt="Robin Chalas" loading="lazy" width="24" height="24">
                        <img class="size-6 rounded-full ring-2 ring-white" src="{{ asset('images/team/members/mathias-arlaud.jpg') }}" alt="Mathias Arlaud" loading="lazy" width="24" height="24">
                    </div>
                    <span class="text-sm text-gray-500 max-sm:hidden">{{ 'home.code.released_by'|trans({name1: '<span class="font-semibold text-slate-700">Robin Chalas</span>', name2: '<span class="font-semibold text-slate-700">Mathias Arlaud</span>'})|raw }}</span>
                    <span class="text-xs text-gray-500 sm:hidden">{{ 'home.code.released_this'|trans }}</span>
                </div>
            </div>

            {# Release body — the 3 values as changelog entries #}
            <div class="px-6 sm:px-8 py-8 sm:py-10 space-y-10">

                {# v3.0 — Pragmatic technologists #}
                <div>
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-4">
                        <span class="shrink-0 self-start font-mono text-xs font-semibold bg-violet-100 text-violet-700 rounded-full px-3 py-1 ring-1 ring-inset ring-violet-200">v3.0</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-slate-900">
                            {{- 'home.code.pragmatic_technologists.title'|trans|replace({
                                '<0>': '<span class="text-violet-600">',
                                '</0>': '</span>',
                            })|raw -}}
                        </h3>
                    </div>
                    <div class="pl-0 sm:pl-16 space-y-3 text-gray-600 text-sm sm:text-base/relaxed">
                        <p>{{- 'home.code.pragmatic_technologists.content_1'|trans|replace({
                            '<0>': '<span class="font-semibold text-slate-800">',
                            '</0>': '</span>',
                        })|raw -}}</p>
                        <p>{{ 'home.code.pragmatic_technologists.content_2'|trans }}</p>
                    </div>
                </div>

                <div class="border-t border-gray-100"></div>

                {# v2.0 — Symfony evangelist #}
                <div>
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-4">
                        <span class="shrink-0 self-start font-mono text-xs font-semibold bg-indigo-100 text-indigo-700 rounded-full px-3 py-1 ring-1 ring-inset ring-indigo-200">v2.0</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-slate-900">
                            {{- 'home.code.symfony_evangelist.title'|trans|replace({
                                '<0/>': component('UX:Icon', {name: 'logos:symfony', 'aria-label': 'Symfony', class: 'inline h-6 sm:h-8 mb-0.5 sm:mb-1'}),
                                '<1>': '<span class="text-indigo-600">',
                                '</1>': '</span>',
                            })|raw -}}
                        </h3>
                    </div>
                    <div class="pl-0 sm:pl-16 space-y-3 text-gray-600 text-sm sm:text-base/relaxed">
                        <p>{{- 'home.code.symfony_evangelist.content_1'|trans|replace({
                            '<0>': '<span class="font-semibold text-slate-800">',
                            '</0>': '</span>',
                        })|raw -}}</p>
                    </div>
                </div>

                <div class="border-t border-gray-100"></div>

                {# v1.0 — A real OSS company #}
                <div>
                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-4">
                        <span class="shrink-0 self-start font-mono text-xs font-semibold bg-blue-100 text-blue-700 rounded-full px-3 py-1 ring-1 ring-inset ring-blue-200">v1.0</span>
                        <h3 class="text-xl sm:text-2xl font-bold text-slate-900">
                            {{- 'home.code.real_oss_company.title'|trans|replace({
                                '<0>': '<span class="text-blue-600">',
                                '</0>': '</span>',
                            })|raw -}}
                        </h3>
                    </div>
                    <div class="pl-0 sm:pl-16 space-y-3 text-gray-600 text-sm sm:text-base/relaxed">
                        <p>{{ 'home.code.real_oss_company.content_1'|trans }}</p>
                        <p>{{ 'home.code.real_oss_company.content_2'|trans }}</p>
                        <p class="font-bold text-slate-900">{{ 'home.code.real_oss_company.content_3'|trans }}</p>
                    </div>
                </div>

            </div>

            {# Footer — tags #}
            <div class="px-6 sm:px-8 py-4 bg-gray-50 border-t border-gray-200" aria-hidden="true">
                <div class="flex items-center gap-2 text-sm text-gray-500">
                    <twig:UX:Icon name="octicon:tag" aria-hidden="true" class="size-4" />
                    <span>oss-company</span>
                    <span class="mx-1">·</span>
                    <span>symfony-evangelist</span>
                    <span class="mx-1">·</span>
                    <span>pragmatic</span>
                </div>
            </div>

        </div>

    </div>
</section>
