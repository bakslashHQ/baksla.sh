        titleKey: 'home.products.product.coaching.title',
        contentKey: 'home.products.product.coaching.content',
        replacements: {
            '<0>': '<span class="inline-flex items-center gap-1 rounded-full bg-purple-50 px-2.5 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-200 align-middle mx-0.5">' ~ component('UX:Icon', {name: 'mdi:brain', 'aria-hidden': true, class: 'size-3.5'}),
