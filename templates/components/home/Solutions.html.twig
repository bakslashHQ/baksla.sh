    {
        filename: 'custom-development.md',
        titleKey: 'home.products.product.custom_symfony_development.title',
        contentKey: 'home.products.product.custom_symfony_development.content',
        replacements: {'<0>': '<span class="font-semibold text-slate-900">', '</0>': '</span>'},
    },
    {
