<div class="relative flex items-center gap-3 px-4 py-3 rounded-xl bg-accent/[0.08] border border-accent/30 text-ink shadow-sm font-article">
    <span aria-hidden="true" class="shrink-0 size-9 rounded-full bg-accent text-paper flex items-center justify-center">
        <twig:ux:icon name="mdi:lightbulb-on-outline" aria-hidden="true" class="size-5" />
    </span>
    <div class="min-w-0 flex-1">
        <div class="font-mono text-[0.625rem] uppercase tracking-widest text-accent font-bold">{{ 'team.pr.tip.label'|trans }}</div>
        <div class="font-sans text-[0.9375rem] leading-snug text-ink">
            {{ 'team.pr.tip.body'|trans }}
        </div>
    </div>
</div>
