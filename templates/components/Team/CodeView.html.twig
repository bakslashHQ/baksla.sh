{% set codeOpen = '<code class="inline-code">' %}
{% set codeClose = '</code>' %}

{% set anchorOpen = '<a href="%href%" target="_blank" class="text-accent underline underline-offset-4">' %}
{% set anchorClose = '<span class="sr-only"> (' ~ ('common.opens_new_tab'|trans) ~ ')</span></a>' %}

{% set mergeSummary -%}
    {{- 'team.pr.merge_summary'|trans|replace({
        '<0>': '<span class="text-ink font-semibold">',
        '</0>': '</span>',
        '<1>': '<span class="text-ink font-semibold">',
        '</1>': '</span>',
        '<2>': '<span class="px-1.5 py-0.5 rounded bg-ink/[0.06] text-ink">',
        '</2>': '</span>',
        '<3>': '<span class="px-1.5 py-0.5 rounded bg-accent/10 text-accent font-semibold">',
        '</3>': '</span>',
    })|raw -}}
{%- endset %}

<article data-test-review aria-labelledby="pr-title" class="bg-paper border border-ink/15 rounded-2xl overflow-hidden shadow-lg">
    <div class="px-5 sm:px-6 pb-4 sm:pb-5 pt-6 border-b border-ink/10 bg-paper-shade/40">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-xs">
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-accent/10 text-accent font-bold uppercase tracking-widest">
                <twig:ux:icon name="mdi:circle" aria-hidden="true" class="size-3" />
                {{ 'team.pr.status_open'|trans }}
            </span>
            <span class="hidden sm:inline text-muted">{{ mergeSummary }}</span>
        </div>

        <h2 id="pr-title" class="mt-3 font-sans font-semibold tracking-tight text-2xl sm:text-3xl text-ink leading-tight">
            {{- 'team.pr.title'|trans|replace({
                '<0>': '<span class="px-1.5 py-0.5 rounded bg-ink/[0.06] text-ink font-mono text-[0.85em]">',
                '</0>': '</span>',
            })|raw -}}
        </h2>

        <div class="rule-dotted mt-4 mb-5 sm:mt-8 sm:mb-5"></div>

        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 font-mono text-xs text-muted">
            <span class="inline-flex items-center gap-1.5">
                <twig:ux:icon name="mdi:file-document-outline" aria-hidden="true" class="size-3.5" />
                <span class="text-ink hidden sm:inline">{{ 'team.pr.file_path_full'|trans }}</span>
                <span class="text-ink sm:hidden">{{ 'team.pr.file_path_short'|trans }}</span>
            </span>
            <span class="ml-auto inline-flex items-center gap-2">
                <span class="inline-flex items-center gap-1 text-green-700 font-bold">
                    <twig:ux:icon name="mdi:plus" aria-hidden="true" class="size-3" />12
                </span>
                <span class="inline-flex items-center gap-1 text-red-700 font-bold">
                    <twig:ux:icon name="mdi:minus" aria-hidden="true" class="size-3" />1
                </span>
            </span>
        </div>
    </div>

    <div class="px-5 sm:px-6 py-3 border-b border-ink/10 flex items-center gap-3 bg-paper-shade/30">
        <span aria-hidden="true" class="font-mono text-xs flex items-center gap-1.5">
            <span class="size-2 inline-block bg-green-600"></span>
            <span class="size-2 inline-block bg-green-600"></span>
            <span class="size-2 inline-block bg-green-600"></span>
            <span class="size-2 inline-block bg-green-600"></span>
            <span class="size-2 inline-block bg-red-700/80"></span>
            <span class="size-2 inline-block bg-ink/15"></span>
        </span>
        <span class="font-mono text-xs text-ink truncate">
            <span class="sm:hidden">{{ 'team.pr.file_path_short'|trans }}</span>
            <span class="hidden sm:inline">{{ 'team.pr.file_path_full'|trans }}</span>
        </span>
    </div>

