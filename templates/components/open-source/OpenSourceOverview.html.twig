{% set bundleStats = this.bundleStats %}
{% set contributionsByProject = this.contributionsByProject %}

<section aria-label="Open source contributions" class="pt-12 sm:pt-16 pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">

        {# PR Header — GitHub PR title style #}
        <div class="pb-6 border-b border-gray-200">
            <h2 class="text-2xl sm:text-3xl font-normal text-slate-800 tracking-tight">
                {{ 'home.open_source.subtitle'|trans }}
            </h2>
            <div class="mt-3 flex flex-wrap items-center gap-3">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-purple-600 px-3 py-1 text-xs font-semibold text-white">
                    <twig:UX:Icon name="octicon:git-pull-request" aria-hidden="true" class="size-4" />
                    {{ 'home.open_source.merged'|trans }}
                </span>
                <span class="text-sm text-gray-500">baksla.sh {{ 'home.open_source.merged_into'|trans }} <span class="font-mono text-xs bg-blue-50 text-blue-700 rounded-md px-2 py-0.5 ring-1 ring-inset ring-blue-200">ecosystem</span></span>
            </div>
        </div>

        {# Main content + Sidebar #}
        <div class="mt-8 flex gap-8 lg:gap-12">

            {# Timeline #}
            <div class="flex-1 min-w-0">
                <div class="relative border-l-2 border-gray-200 ml-3">

                    {# Project stats — loop driven #}
                    {% for stats in this.mainProjectStats %}
                        <div class="relative pl-7 pb-10">
                            <twig:ui:TimelineDot color="green">
                                <twig:UX:Icon name="octicon:check" aria-hidden="true" class="size-3.5" />
                            </twig:ui:TimelineDot>
                            <div class="rounded-lg bg-white border border-gray-200">
                                <div class="flex items-center justify-between gap-4 bg-gray-50 px-4 py-2.5 rounded-t-lg border-b border-gray-200">
                                    <div class="flex items-center gap-2.5 min-w-0">
                                        <twig:UX:Icon name="{{ stats.project.icon }}" aria-label="{{ stats.project.label }}" class="h-5 shrink-0" />
                                        <span class="font-semibold text-sm text-slate-800 truncate">{{ stats.project.label }}</span>
                                    </div>
                                    <a href="{{ stats.project.url }}" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-400 hover:text-indigo-600 transition font-mono truncate max-sm:hidden">{{ stats.project.url|replace({'https://github.com/': ''}) }}</a>
                                </div>
                                <div class="flex gap-8 px-4 py-4">
                                    <div>
                                        <span class="block text-3xl sm:text-4xl font-bold text-slate-800">{{ stats.reviews|number_format }}</span>
                                        <span class="text-xs sm:text-sm text-gray-500">{{ 'home.open_source.stats.reviews'|trans }}</span>
                                    </div>
                                    <div>
                                        <span class="block text-3xl sm:text-4xl font-bold text-slate-800">{{ stats.pullRequests|number_format }}</span>
                                        <span class="text-xs sm:text-sm text-gray-500">{{ 'home.open_source.stats.pull_requests'|trans }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}

                    {# Major contributions #}
                    {% if contributionsByProject['symfony'] is defined %}
                        <div class="relative pl-7 pb-10">
                            <twig:ui:TimelineDot color="gray">
                                <twig:UX:Icon name="octicon:git-commit" aria-hidden="true" class="size-3.5" />
                            </twig:ui:TimelineDot>
                            <div class="flex items-center gap-2 mb-4">
                                <span class="text-sm text-gray-500">{{ 'home.open_source.contributions_count'|trans({count: contributionsByProject['symfony']|length}) }}</span>
                            </div>
                            <ul class="space-y-1">
                                {% for contribution in contributionsByProject['symfony'] %}
                                    <li>
                                        <a href="{{ contribution.url }}" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-lg px-3 py-2.5 -mx-3 transition hover:bg-blue-50">
                                            <img class="size-7 rounded-full ring-1 ring-gray-200 shrink-0" src="{{ asset('images/team/members/' ~ contribution.creator.value ~ '.jpg') }}" alt="{{ contribution.creator.value|replace({'-': ' '})|title }}" loading="lazy" width="28" height="28">
                                            <div class="min-w-0 flex-1">
                                                <span class="text-sm font-semibold text-slate-800 group-hover:text-indigo-600 transition">{{ contribution.name }}</span>
                                                <p class="text-xs text-gray-500 truncate max-sm:hidden">{{ contribution.description }}</p>
                                            </div>
                                            <twig:ui:Badge color="purple" class="hidden sm:inline-flex">{{ 'home.open_source.merged'|trans|lower }}</twig:ui:Badge>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    {# Maintained bundles #}
                    <div class="relative pl-7 pb-10">
                        <twig:ui:TimelineDot color="gray">
                            <twig:UX:Icon name="octicon:repo" aria-hidden="true" class="size-3.5" />
                        </twig:ui:TimelineDot>
                        <div class="rounded-lg bg-white border border-gray-200">
                            <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-1 bg-gray-50 px-4 py-2.5 rounded-t-lg border-b border-gray-200">
                                <span class="font-semibold text-sm text-slate-800">{{ 'home.open_source.maintained_bundles'|trans }}</span>
                                <div class="flex gap-4 text-xs sm:text-sm">
                                    <span class="text-slate-800 font-bold">{{ bundleStats.reviews|number_format }} <span class="text-gray-400 font-normal">{{ 'home.open_source.stats.reviews'|trans }}</span></span>
                                    <span class="text-slate-800 font-bold">{{ bundleStats.pullRequests|number_format }} <span class="text-gray-400 font-normal">{{ 'home.open_source.stats.pull_requests'|trans }}</span></span>
                                </div>
                            </div>
                            <ul class="px-4 py-3 space-y-1">
                                {% for bundle in this.bundles %}
                                    <li>
                                        <a href="{{ bundle.url }}" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 py-1 transition">
                                            <span class="text-sm text-gray-700 group-hover:text-indigo-600 transition font-medium">{{ bundle.label }}</span>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    {# Merge event #}
                    <div class="relative pl-7">
                        <twig:ui:TimelineDot color="purple">
                            <twig:UX:Icon name="octicon:git-pull-request" aria-hidden="true" class="size-3.5" />
                        </twig:ui:TimelineDot>
                        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-gray-500">
                            <span class="font-semibold text-slate-800">baksla.sh</span>
                            <span>{{ 'home.open_source.merged_into'|trans }}</span>
                            <twig:ui:Badge color="blue">ecosystem</twig:ui:Badge>
                        </div>
                    </div>

                </div>
            </div>

            {# Sidebar #}
            <aside class="hidden lg:block w-56 shrink-0 border-l border-gray-200 pl-8">
                <div class="sticky top-[8rem] space-y-8">

                    {# Labels #}
                    <div>
                        <h3 class="text-xs font-semibold text-slate-800 mb-3">{{ 'home.open_source.sidebar.labels'|trans }}</h3>
                        <div class="flex flex-wrap gap-1.5">
                            {% for label in this.labels %}
                                <twig:ui:Badge :color="label.color">{{ label.label }}</twig:ui:Badge>
                            {% endfor %}
                        </div>
                    </div>

                    {# Reviewers #}
                    <div>
                        <h3 class="text-xs font-semibold text-slate-800 mb-3">{{ 'home.open_source.sidebar.reviewers'|trans }}</h3>
                        <ul class="space-y-2.5">
                            {% for reviewer in this.reviewers %}
                                <twig:ui:Reviewer :memberId="reviewer.memberId" :name="reviewer.name" />
                            {% endfor %}
                        </ul>
                    </div>

                    {# Milestone #}
                    <div>
                        <h3 class="text-xs font-semibold text-slate-800 mb-3">{{ 'home.open_source.sidebar.milestone'|trans }}</h3>
                        <div class="w-full h-2 bg-gray-200 rounded-full overflow-hidden mb-2" aria-hidden="true">
                            <div class="h-full bg-green-600 rounded-full" style="width: 100%"></div>
                        </div>
                        <span class="text-sm text-slate-700">{{ 'home.open_source.sidebar.milestone.ecosystem'|trans }}</span>
                    </div>

                </div>
            </aside>

        </div>
    </div>
</section>
