<dialog
    aria-labelledby="modal-title-{{ member.id.value }}"
    aria-describedby="modal-description-{{ member.id.value }}"
    aria-modal="true"
    data-controller="member-modal"
    data-member-modal-member-value="{{ member.id.value }}"
    data-action="click->member-modal#close:self"
    class="bg-transparent px-4 py-5 w-screen max-w-2xl backdrop:bg-black/20 backdrop:backdrop-blur-sm"
>
    <div data-member-modal-target="modal" class="transform rounded-xl text-left shadow-lg transition-all mt-6 sm:mt-12 pointer-events-auto ease-in-out duration-300 opacity-0 translate-y-4 scale-80 bg-white ring-1 ring-gray-300 overflow-hidden max-h-[85vh] overflow-y-auto">

        {# Header — GitHub profile style #}
        <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <img class="size-10 rounded-full ring-2 ring-white shadow-sm" src="{{ asset('images/team/members/' ~ member.id.value ~ '.jpg') }}" alt="{{ member.fullName }}" loading="lazy" />
                <div>
                    <h3 class="text-lg font-bold text-slate-900" id="modal-title-{{ member.id.value }}">
                        {{ member.fullName }}
                        {% if member.nickName %}
                            <span class="text-gray-400 font-normal text-sm ml-1">{{ member.nickName }}</span>
                        {% endif %}
                    </h3>
                    <div class="flex flex-wrap gap-1.5 mt-1">
                        {% for badge in member.badges %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                                {% if badge.uxIcon %}
                                    <twig:UX:Icon name="{{ badge.uxIcon }}" aria-label="{{ badge.uxIconLabel }}" class="size-3" />
                                {% endif %}
                                {{ badge.text }}
                            </span>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <button type="button" data-action="click->member-modal#close" aria-label="{{ 'team.modal.close'|trans }}" autofocus class="text-gray-400 hover:text-gray-600 transition p-2 rounded-md hover:bg-gray-100 cursor-pointer">
                <twig:UX:Icon name="octicon:x" aria-hidden="true" class="size-5" />
            </button>
        </div>

        {# Bio — styled as a README #}
        <div class="px-6 py-6">
            <div class="flex items-center gap-2 text-xs text-gray-400 mb-4">
                <twig:UX:Icon name="octicon:file" aria-hidden="true" class="size-4" />
                README.md
            </div>
            <p id="modal-description-{{ member.id.value }}" class="text-sm text-gray-700 leading-relaxed">{{ ('team.bio.' ~ member.id.value)|trans|nl2br }}</p>
        </div>

        {# Footer — social links #}
        <div class="flex items-center justify-between px-6 py-3 bg-gray-50 border-t border-gray-200">
            <ul class="flex items-center gap-3">
                {% for socialNetwork in member.socialNetworks %}
                    <li>
                        <a href="{{ socialNetwork.url }}" target="_blank" aria-label="{{ socialNetwork.uxIconLabel }}" class="text-gray-400 hover:text-slate-700 transition">
                            <twig:UX:Icon name="{{ socialNetwork.uxIcon }}" aria-hidden="true" class="size-5" />
                        </a>
                    </li>
                {% endfor %}
            </ul>
            <button type="button" data-action="click->member-modal#close" class="inline-flex items-center gap-1.5 rounded-md bg-white px-3 py-1.5 text-sm font-medium text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-100 transition cursor-pointer">
                👍 {{ 'team.modal.nice'|trans }}
            </button>
        </div>

    </div>
</dialog>
