<div class="hidden relative z-10" aria-labelledby="modal-title" role="dialog" aria-modal="true" data-controller="member-modal" data-member-modal-member-value="{{ member.id.value }}">
    <div data-member-modal-target="backdrop" data-action="click->member-modal#close" class="fixed inset-0 bg-gray-900/70 transition-all ease-in-out duration-300" aria-hidden="true"></div>

    <div class="fixed inset-0 z-10 overflow-y-auto pointer-events-none">
        <div class="flex min-h-full justify-center p-4 text-center items-center">
            <div data-member-modal-target="modal" class="relative transform rounded-xl bg-white text-left shadow-xl transition-all my-8 w-screen max-w-2xl pointer-events-auto ease-in-out duration-300 opacity-0 translate-y-4 scale-80" data-member-modal-target="content">
                <div class="bg-white px-10 py-12 relative rounded-t-xl">
                    <img class="absolute -translate-y-28 left-1/2 -translate-x-1/2 size-40 rounded-full bg-gray-50 shadow-xl shadow-blue-gray-900/50" src="{{ asset('images/team/members/' ~ member.picture) }}" alt="{{ member.firstName ~ ' ' ~ member.lastName }}" />
                    <div class="mt-12 flex flex-col gap-y-6">
                        <h3 class="text-center mt-6 text-4xl font-bold tracking-tight text-slate-800" id="modal-title">{{ member.firstName ~ ' ' ~ member.lastName }}</h3>
                        <div class="flex flex-row flex-wrap gap-x-3 gap-y-2 pb-8 justify-center items-center border-b border-gray-300">
                            <div class="text-sm border border-1 border-gray-300 rounded-full py-.5 px-2 grow-0 flex flex-row items-center gap-x-1 whitespace-nowrap">
                                <twig:UX:Icon name="logos:bakslash" aria-label="Bakslash" class="size-4" />
                                COO
                            </div>
                            <div class="text-sm border border-1 border-gray-300 rounded-full py-.5 px-2 grow-0 flex flex-row items-center gap-x-1 whitespace-nowrap">
                                <twig:UX:Icon name="logos:symfony" aria-label="Symfony" class="h-4" />
                                Core Team
                            </div>
                            <div class="text-sm border border-1 border-gray-300 rounded-full py-.5 px-2 grow-0 flex flex-row items-center gap-x-1 whitespace-nowrap">
                                <twig:UX:Icon name="logos:symfony" aria-label="Symfony" class="h-4" />
                                Certified (expert)
                            </div>
                        </div>
                        <p class="mt-2 text-base text-justify text-gray-700 font-article">
                            {{ member.bio|nl2br }}
                        </p>
                    </div>
                </div>
                <div class="flex justify-between items-center bg-gray-50 py-3 px-6 border-t border-gray-200 rounded-b-xl">
                    <ul class="flex justify-center items-center text-sm font-medium h-full">
                    {% for socialNetwork in member.socialNetworks %}
                        <li>
                            <a href="{{ socialNetwork.url }}" aria-label="{{ socialNetwork.label }}" class="hover:underline me-5 h-full flex items-center">
                                <twig:UX:Icon name="{{ socialNetwork.uxIcon }}" class="h-5 opacity-70 hover:opacity-100 transition" />
                            </a>
                        </li>
                    {% endfor %}
                    </ul>
                    <button type="button" data-action="click->member-modal#close" class="inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto">👍 Nice!</button>
                </div>
            </div>
        </div>
    </div>
</div>
