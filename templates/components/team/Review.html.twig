<div class="bg-white font-article p-3 sm:p-4 flex max-lg:justify-center border-y border-gray-200">
    <div class="grow max-w-2xl flex flex-col gap-y-5 rounded-lg bg-white text-sm/6 border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 py-2 bg-gray-50 border-b border-gray-200 flex items-center gap-2 text-xs text-gray-500">
            <twig:UX:Icon name="octicon:comment" aria-hidden="true" class="size-3.5 text-gray-400" />
            {{ 'home.team.review_thread'|trans }}
        </div>
        <div class="px-4 pb-4 flex flex-col gap-y-5">
            {% block content %}{% endblock %}
        </div>
    </div>
</div>
