<div data-test-review-comment class="flex items-start gap-3">
    <button type="button" data-open-member-modal="{{ member.id.value }}" aria-label="{{ 'team.view_profile'|trans({'name': member.fullName}) }}" class="shrink-0 cursor-pointer">
        <img class="size-8 rounded-full ring-1 ring-gray-200" src="{{ asset('images/team/members/' ~ member.id.value ~ '.jpg') }}" alt="{{ member.fullName }}" loading="lazy" />
    </button>
    <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-1">
            <button type="button" data-open-member-modal="{{ member.id.value }}" aria-label="{{ 'team.view_profile'|trans({'name': member.fullName}) }}" class="cursor-pointer">
                <span data-test-review-comment-reviewer class="text-sm font-semibold text-slate-800 hover:text-indigo-600 transition">{{ member.fullName }}</span>
            </button>
            {% for badge in member.badges %}
                <span class="inline-flex items-center gap-1 rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500 max-md:hidden">
                    {% if badge.uxIcon %}
                        <twig:UX:Icon name="{{ badge.uxIcon }}" aria-label="{{ badge.uxIconLabel }}" class="size-3" />
                    {% endif %}
                    {{ badge.text }}
                </span>
            {% endfor %}
        </div>
        <div class="text-sm text-gray-700 leading-relaxed">{% block content %}{% endblock %}</div>
    </div>
</div>
