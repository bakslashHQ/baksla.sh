{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "~8.4.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-imagick": "*",
        "fakerphp/faker": "^1.24.1",
        "league/commonmark": "^2.8.2",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "sensiolabs/minify-bundle": "dev-feat/html-support as 1.3.0",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/cache": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/emoji": "8.1.*",
        "symfony/expression-language": "8.1.*",
        "symfony/filesystem": "8.1.*",
        "symfony/finder": "8.1.*",
        "symfony/flex": "^2.11.0",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/intl": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/mime": "8.1.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/process": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/stimulus-bundle": "^3.2",
        "symfony/string": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/ux-icons": "^3.2",
        "symfony/ux-twig-component": "^3.2",
        "symfony/validator": "8.1.*",
        "symfony/web-link": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/tailwind-bundle": "^0.13.0",
        "tempest/highlight": "^2.26",
        "twig/extra-bundle": "^3.24",
        "twig/html-extra": "^3.24",
        "twig/intl-extra": "^3.26",
        "twig/twig": "^3.26"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd",
            "tailwind:build --minify": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*",
            "docker": true
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/bakslashHQ/minify-bundle"
        }
    ],
    "require-dev": {
        "kocal/biome-js-bundle": "^2.1.2",
        "kocal/phpstan-symfony-ux": "^1.3",
        "phpstan/phpstan": "^2.2.2",
        "phpstan/phpstan-symfony": "^2.0.20",
        "phpunit/phpunit": "^13.2",
        "playwright-php/playwright": "^1.2",
        "rector/rector": "^2.4.6",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*",
        "symplify/easy-coding-standard": "^13.2",
        "vincentlanglet/twig-cs-fixer": "^4.0"
    }
}
